# FieldSync Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=fieldsync
DB_PORT=3306

# JWT Authentication (generate strong random secrets)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_strong_random_secret_here
JWT_REFRESH_SECRET=generate_a_different_strong_random_secret_here
JWT_EXPIRES_IN=1d

# Email (Gmail App Password for nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# CSRF
CSRF_SECRET=generate_another_strong_random_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ─── Production overrides ───────────────────────────────────
# NODE_ENV=production
# DB_HOST=your-production-db-host
# DB_PASSWORD=your-production-db-password
# FRONTEND_URL=https://fieldsync.com

# ─── Sentry Error Tracking (optional) ──────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/your-project
